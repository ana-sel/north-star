# North Star backend environment example.
# Copy to .env and adjust as needed.

DATABASE_URL=postgresql+psycopg://northstar:northstar_dev@localhost:5432/northstar
OLLAMA_BASE_URL=http://localhost:11434
APP_ENV=development

# Redactor (Phase 3)
# Optional path to a JSON file with personal vocabulary, e.g.:
# {"PERSON_NAME": ["Ana"], "CITY": ["Vilnius"], "EMPLOYER": ["Acme"]}
REDACTOR_VOCAB_PATH=
# Set to true to enable a local-only Ollama pass that catches what
# regex/vocab miss.  Adds latency; recommended only for sensitive prompts.
REDACTOR_SEMANTIC_ENABLED=false
REDACTOR_SEMANTIC_MODEL=llama3.2
